{
	"version": 1,
	"base_image": "codeocean/tensorflow:2.11-python3.10-cuda11.7.0-runtime-ubuntu22.04",
	"post_install": true,
	"options": {
		"registry_host_arg": true,
		"git_ask_pass": true,
		"mount_secrets": true
	},
	"installers": {
		"apt": {
			"packages": [
				{
					"name": "libcublas-12-1",
					"version": "12.1.3.1-1"
				},
				{
					"name": "libgl1",
					"version": "1.4.0-1"
				}
			],
			"install_software_properties_common": true
		}
	}
}